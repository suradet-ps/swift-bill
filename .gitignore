# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Bun — install cache (binary lockfile .lockb is also produced by
# older bun versions but is git-unfriendly; we track bun.lock).
.bun/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Rust / Cargo workspace artifacts
# The workspace root produces a single shared /target/ now that all
# members (crates/* and src-tauri) live under one Cargo workspace.
# /target/ at the workspace root supersedes the per-crate /target/
# entries that src-tauri/.gitignore used to carry.
# Cargo.lock is intentionally NOT ignored — Swift Bill is a binary
# application, so reproducible builds require locking the dep graph.
target/
src-tauri/target/

# Generated output
src-tauri/output/
output/
*.pdf
!crates/swift-bill-pdf/assets/template_cover.pdf
